# ========================================
# 业问后端环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ========================================

# 应用
DEBUG=true

# 数据库（开发环境默认 SQLite，生产环境使用 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./yewen.db
# DATABASE_URL=postgresql+asyncpg://yewen:your_password@localhost:5432/yewen

# JWT — ⚠️ 生产环境必须修改为强随机密钥（至少32字符）
# 可用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRE_HOURS=168

# 微信小程序 — 登录功能必需
WX_APPID=
WX_SECRET=

# CORS — 允许的前端域名，多个用逗号分隔，开发模式可用 *
CORS_ORIGINS=*

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
