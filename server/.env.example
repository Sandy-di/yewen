# 业问后端环境变量配置

# 数据库连接（开发用 SQLite，生产用 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./yewen.db
# DATABASE_URL=postgresql+asyncpg://yewen:yewen_dev_2026@localhost:5432/yewen

# JWT 密钥（生产环境务必更换！）
JWT_SECRET=yewen-jwt-secret-change-in-production

# 微信小程序配置
WX_APPID=你的小程序appid
WX_SECRET=你的小程序secret

# 调试模式
DEBUG=true

# Token 过期时间（小时）
JWT_EXPIRE_HOURS=168
