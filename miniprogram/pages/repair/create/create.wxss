/* pages/repair/create/create.wxss — 深空科技风格 */

.page-repair-create {
  min-height: 100vh;
  background: var(--bg-page);
}

/* 类型网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.category-item {
  width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg) 12rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  transition: all 0.2s;
  background: rgba(255, 255, 255, 0.02);
}

.category-item:active {
  background: rgba(102, 125, 150, 0.06);
}

.category-active {
  border-color: var(--primary);
  background: var(--primary-light);
  box-shadow: 0 12rpx 24rpx rgba(102, 125, 150, 0.10);
}

.category-icon {
  font-size: 44rpx;
  margin-bottom: var(--space-xs);
}

.category-label {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.category-active .category-label {
  color: var(--primary);
  font-weight: 600;
}

/* 子分类 */
.sub-categories {
  margin-top: var(--space-lg);
  padding-top: var(--space-lg);
  border-top: 1rpx solid var(--border);
}

.sub-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
}

.sub-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sub-item {
  padding: 12rpx 24rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  font-size: 24rpx;
  color: var(--text-primary);
  transition: all 0.2s;
}

.sub-item:active {
  background: rgba(102, 125, 150, 0.06);
}

.sub-active {
  border-color: var(--primary);
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 600;
}

/* 匿名行 */
.anonymous-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.anonymous-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 提交区 */
.submit-section {
  padding: 40rpx 0;
}
