/* pages/repair/detail/detail.wxss */

.page-repair-detail {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.status-header {
  margin: var(--space-md) var(--space-lg) 0;
  padding: 28rpx var(--space-lg);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg), var(--shadow-inset);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.status-submitted,
.status-accepted,
.status-processing {
  background: linear-gradient(180deg, #FFFFFF 0%, #F3F6FA 100%);
}

.status-pending_check {
  background: linear-gradient(180deg, #FFFFFF 0%, #FBF5EC 100%);
}

.status-completed {
  background: linear-gradient(180deg, #FFFFFF 0%, #F2F8F4 100%);
}

.status-rework {
  background: linear-gradient(180deg, #FFFFFF 0%, #FAF1F1 100%);
}

.status-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #FFFFFF 0%, #EEF3F7 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
}

.status-info {
  flex: 1;
}

.status-label {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.status-time {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: var(--text-primary);
}

.repair-desc {
  margin-bottom: 20rpx;
}

.desc-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.desc-content,
.completion-note {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.repair-photo {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: var(--shadow-sm);
}

.worker-info {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.worker-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #FFFFFF 0%, #EEF3F7 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  flex-shrink: 0;
}

.worker-detail {
  flex: 1;
}

.worker-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.worker-time {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.rating-stars,
.rating-stars-large {
  display: flex;
  gap: 10rpx;
}

.rating-stars {
  margin-bottom: 14rpx;
}

.star,
.star-lg {
  color: rgba(194, 154, 99, 0.32);
}

.star {
  font-size: 32rpx;
}

.star-lg {
  font-size: 58rpx;
  justify-content: center;
}

.rating-stars-large {
  justify-content: center;
  margin-bottom: 24rpx;
}

.star-active,
.star-lg-active {
  color: var(--warning);
}

.rating-comment {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx var(--space-lg);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(251, 251, 252, 0.92);
  backdrop-filter: blur(16rpx);
  border-top: 1rpx solid rgba(152, 162, 179, 0.16);
  z-index: 50;
}

.bottom-actions .btn {
  flex: 1;
}

.bottom-actions .share-btn-fix {
  flex: 1;
  padding: 0;
  margin: 0;
  line-height: inherit;
  background: transparent;
  border: 1rpx solid rgba(148, 163, 184, 0.3);
}

.bottom-actions .share-btn-fix::after {
  border: none;
}
