/* pages/repair/list/list.wxss — 深空科技风格 */

.page-repair-list {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* Tab — 药丸式 */
.tabs-pill-custom {
  margin: var(--space-md) var(--space-lg) 0;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid var(--border);
}

/* 工单列表 */
.order-list {
  padding: var(--space-md) var(--space-lg);
}

.order-card {
  margin-bottom: var(--space-md);
  padding: 0;
  overflow: hidden;
  display: flex;
}

/* 左侧状态色条 — 发光 */
.order-status-bar {
  width: 6rpx;
  flex-shrink: 0;
}

.bar-pending {
  background: var(--warning);
  box-shadow: 0 0 12rpx rgba(255, 215, 64, 0.4);
}

.bar-processing {
  background: var(--primary);
  box-shadow: 0 0 12rpx rgba(0, 229, 255, 0.4);
}

.bar-completed {
  background: var(--success);
  box-shadow: 0 0 12rpx rgba(0, 230, 118, 0.4);
}

.bar-cancelled {
  background: var(--text-disabled);
}

.order-card-content {
  flex: 1;
  padding: var(--space-lg);
}

.order-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.order-type {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.order-type-icon {
  font-size: 32rpx;
}

.order-type-label {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.order-card-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: var(--space-sm);
}

.order-card-photos {
  display: flex;
  gap: 12rpx;
  margin-bottom: var(--space-sm);
}

.order-photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--border);
}

.order-card-footer {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}

.order-time {
  font-size: 24rpx;
  color: var(--text-disabled);
}

.order-id {
  font-size: 20rpx;
  letter-spacing: 0.5px;
}

.order-action {
  margin-left: auto;
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
}

/* 空状态 */
.empty-state-icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
}

.empty-state-icon-text {
  font-size: 48rpx;
  color: var(--text-disabled);
}
