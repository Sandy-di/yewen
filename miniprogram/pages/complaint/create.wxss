.page { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }
.form-card { background: #fff; border-radius: 16rpx; padding: 32rpx; }
.form-item { margin-bottom: 32rpx; }
.label { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; display: block; }
.input { border: 1rpx solid #e5e5e5; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; }
.picker { border: 1rpx solid #e5e5e5; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #333; }
.textarea { border: 1rpx solid #e5e5e5; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; min-height: 200rpx; width: 100%; }

.photo-row { display: flex; gap: 16rpx; flex-wrap: wrap; }
.photo-item { position: relative; }
.photo { width: 160rpx; height: 160rpx; border-radius: 12rpx; }
.photo-remove { position: absolute; top: -10rpx; right: -10rpx; width: 36rpx; height: 36rpx; border-radius: 50%; background: #F5222D; color: #fff; font-size: 24rpx; display: flex; align-items: center; justify-content: center; }
.photo-add { width: 160rpx; height: 160rpx; border: 2rpx dashed #d9d9d9; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 56rpx; color: #d9d9d9; }

.submit-btn { margin-top: 40rpx; background: #4A6FA5; color: #fff; border-radius: 12rpx; font-size: 30rpx; padding: 24rpx 0; border: none; }