.page { padding: 0; background: #f5f5f5; min-height: 100vh; }
.header { background: #fff; padding: 32rpx; border-bottom: 1rpx solid #eee; }
.title-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx; }
.title { font-size: 34rpx; font-weight: 700; flex: 1; margin-right: 16rpx; }
.status-badge { font-size: 24rpx; padding: 6rpx 20rpx; border-radius: 24rpx; white-space: nowrap; }
.status-submitted { background: #FFF1F0; color: #F5222D; }
.status-replied { background: #FFFBE6; color: #D48806; }
.status-resolved { background: #F0FFF4; color: #52C41A; }
.status-closed { background: #F5F5F5; color: #999; }
.meta { display: flex; align-items: center; gap: 12rpx; }
.tag { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; background: #E6F7FF; color: #1890FF; }
.important { font-size: 22rpx; color: #FAAD14; }
.time { font-size: 22rpx; color: #bbb; }

.content-card { background: #fff; margin: 20rpx 24rpx; border-radius: 16rpx; padding: 28rpx; }
.content-text { font-size: 28rpx; line-height: 1.8; color: #333; }
.photos { display: flex; gap: 12rpx; flex-wrap: wrap; margin-top: 20rpx; }
.photo { width: 200rpx; height: 200rpx; border-radius: 12rpx; }

.replies { margin: 20rpx 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; color: #333; }
.reply-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 12rpx; border-left: 6rpx solid #4A6FA5; }
.reply-item .reply-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.reply-type { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }
.type-reply { background: #E6F7FF; color: #1890FF; }
.type-supervise { background: #FFFBE6; color: #D48806; }
.type-resolve { background: #F0FFF4; color: #52C41A; }
.reply-time { font-size: 22rpx; color: #bbb; }
.reply-content { font-size: 28rpx; line-height: 1.6; color: #333; }

.actions { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 16rpx; padding: 20rpx 32rpx; background: #fff; border-top: 1rpx solid #eee; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); }
.btn-reply { flex: 1; background: #4A6FA5; color: #fff; border: none; border-radius: 12rpx; font-size: 28rpx; padding: 20rpx 0; }
.btn-supervise { flex: 1; background: #FAAD14; color: #fff; border: none; border-radius: 12rpx; font-size: 28rpx; padding: 20rpx 0; }
.btn-resolve { flex: 1; background: #52C41A; color: #fff; border: none; border-radius: 12rpx; font-size: 28rpx; padding: 20rpx 0; }