/* pages/announce/list/list.wxss — 深空科技风格 */

.page-announce-list {
  min-height: 100vh;
  background: var(--bg-page);
}

/* Tab — 药丸式 */
.tabs-pill-custom {
  margin: var(--space-md) var(--space-lg);
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid var(--border);
}

.announce-list {
  padding: var(--space-md) var(--space-lg);
}

.announce-card {
  margin-bottom: var(--space-md);
}

.announce-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: var(--space-sm);
}

.announce-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-xs);
  font-weight: 600;
  flex-shrink: 0;
  letter-spacing: 0.5px;
}

.announce-badge-notice {
  color: var(--primary);
  background: var(--primary-light);
  border: 1rpx solid rgba(0, 229, 255, 0.2);
}

.announce-badge-vote {
  color: var(--accent);
  background: var(--accent-light);
  border: 1rpx solid rgba(124, 77, 255, 0.2);
}

.announce-badge-finance {
  color: var(--success);
  background: var(--success-light);
  border: 1rpx solid rgba(0, 230, 118, 0.2);
}

.announce-type-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.announce-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.announce-card-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: var(--space-sm);
}

.announce-card-footer {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border);
  font-size: 22rpx;
  color: var(--text-disabled);
}

.announce-reads {
  margin-left: auto;
}
