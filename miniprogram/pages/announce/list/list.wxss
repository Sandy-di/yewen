/* pages/announce/list/list.wxss */

.page-announce-list {
  min-height: 100vh;
  background: var(--bg-page);
}

.tabs-pill-custom {
  margin: var(--space-md) var(--space-lg);
}

.announce-list {
  padding: 0 var(--space-lg) var(--space-lg);
}

.announce-card {
  margin-bottom: var(--space-md);
}

.announce-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.announce-badge {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.announce-badge-notice {
  color: var(--primary-strong);
  background: rgba(102, 125, 150, 0.12);
}

.announce-badge-vote {
  color: var(--accent);
  background: var(--accent-soft);
}

.announce-badge-finance {
  color: var(--success);
  background: var(--success-soft);
}

.announce-type-icon {
  font-size: 28rpx;
  line-height: 1;
}

.announce-card-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.announce-card-content {
  margin-bottom: 18rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.announce-card-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(152, 162, 179, 0.14);
  font-size: 22rpx;
  color: var(--text-secondary);
}

.announce-reads {
  margin-left: auto;
}
