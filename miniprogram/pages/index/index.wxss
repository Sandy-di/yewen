/* pages/index/index.wxss */

.page-index {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(124rpx + env(safe-area-inset-bottom));
}

.announcement-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx var(--space-lg) 0;
  padding: 18rpx 22rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F8FA 100%);
  box-shadow: var(--shadow-sm), var(--shadow-inset);
}

.announcement-bar-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
  flex-shrink: 0;
}

.announcement-bar-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.announcement-bar-close {
  font-size: 24rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.community-header {
  position: relative;
  overflow: hidden;
  margin: var(--space-md) var(--space-lg) 0;
  padding: 40rpx var(--space-lg);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  box-shadow: var(--shadow-lg), var(--shadow-inset);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.community-header-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at right top, rgba(102, 125, 150, 0.14) 0%, rgba(102, 125, 150, 0) 42%);
}

.community-header-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(148, 163, 184, 0.08) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  opacity: 0.32;
}

.community-info,
.header-actions {
  position: relative;
  z-index: 1;
}

.community-info {
  flex: 1;
}

.community-name {
  margin-bottom: 14rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5px;
}

.community-stats {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.stat-item {
  font-size: 42rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.stat-unit {
  color: var(--text-secondary);
}

.stat-divider {
  margin: 0 8rpx;
  color: rgba(152, 162, 179, 0.72);
}

.role-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 56rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(102, 125, 150, 0.14);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: var(--shadow-sm), inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  font-size: 24rpx;
  color: var(--primary-strong);
}

.role-badge-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--primary);
}

.search-bar {
  margin: var(--space-md) var(--space-lg) 0;
}

.tabs-pill-custom {
  margin: var(--space-md) var(--space-lg) 0;
}

.vote-list {
  padding: var(--space-md) var(--space-lg);
}

.vote-card {
  margin-bottom: var(--space-md);
}

.vote-card-header {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.vote-card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.45;
}

.vote-card-progress {
  margin-bottom: 22rpx;
}

.progress-info,
.vote-card-deadline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-info {
  margin-bottom: 12rpx;
}

.progress-text,
.deadline-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.progress-rate {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.vote-card-deadline {
  margin-top: 12rpx;
}

.remain-time {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--warning);
}

.vote-card-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.result-badge {
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 600;
}

.result-pass {
  color: var(--success);
  background: var(--success-soft);
}

.result-fail {
  color: var(--error);
  background: var(--error-soft);
}

.result-participation {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.vote-card-footer {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(152, 162, 179, 0.16);
}

.vote-card-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.vote-card-action {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--primary-strong);
  font-weight: 600;
}

.skeleton-list {
  padding: var(--space-md) var(--space-lg);
}

.skeleton-card {
  padding: var(--space-lg);
}
