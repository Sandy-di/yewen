/* pages/finance/list/list.wxss */

.page-finance {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(124rpx + env(safe-area-inset-bottom));
}

.finance-overview {
  position: relative;
  overflow: hidden;
  margin: var(--space-md) var(--space-lg) 0;
  padding: 34rpx var(--space-lg) 30rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  box-shadow: var(--shadow-lg), var(--shadow-inset);
}

.finance-overview-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(102, 125, 150, 0.16) 0%, rgba(102, 125, 150, 0) 48%);
}

.finance-overview-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(148, 163, 184, 0.08) 1px, transparent 1px);
  background-size: 42rpx 42rpx;
  opacity: 0.3;
}

.overview-title,
.overview-grid {
  position: relative;
  z-index: 1;
}

.overview-title {
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 1px;
}

.overview-grid {
  display: flex;
  align-items: center;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-label {
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.overview-value {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.overview-divider {
  width: 1rpx;
  height: 72rpx;
  background: rgba(148, 163, 184, 0.2);
}

.chart-placeholder {
  padding-top: 4rpx;
}

.bar-chart {
  height: 240rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 48rpx;
  padding: 0 24rpx;
}

.bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.bar {
  width: 42rpx;
  border-radius: 18rpx 18rpx 6rpx 6rpx;
}

.bar-income {
  background: linear-gradient(180deg, #A7C0B0 0%, #6F9A7E 100%);
  box-shadow: 0 8rpx 16rpx rgba(111, 154, 126, 0.18);
}

.bar-expense {
  background: linear-gradient(180deg, #D3A39F 0%, #B77C7A 100%);
  box-shadow: 0 8rpx 16rpx rgba(183, 124, 122, 0.18);
}

.bar-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 28rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 6rpx;
}

.dot-income {
  background: var(--success);
}

.dot-expense {
  background: var(--error);
}

.finance-card {
  margin: var(--space-sm) var(--space-lg) 0;
}

.finance-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.finance-month {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.finance-card-body {
  display: flex;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.finance-stat {
  flex: 1;
  padding: 22rpx 18rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
}

.finance-stat-label {
  display: block;
  margin-bottom: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.finance-stat-value {
  font-size: 28rpx;
  font-weight: 600;
}

.finance-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(152, 162, 179, 0.16);
}

.finance-meta,
.announce-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.finance-action {
  font-size: 24rpx;
  color: var(--primary-strong);
  font-weight: 600;
}

.announce-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(152, 162, 179, 0.14);
}

.announce-item:first-child {
  padding-top: 0;
}

.announce-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.announce-badge {
  display: inline-flex;
  min-height: 42rpx;
  padding: 0 14rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  background: var(--warning-soft);
  color: var(--warning);
  font-size: 20rpx;
  font-weight: 600;
}

.announce-title {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.skeleton-list {
  padding: var(--space-md) var(--space-lg);
}
