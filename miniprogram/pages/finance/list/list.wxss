/* pages/finance/list/list.wxss — 深空科技风格 */

.page-finance {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ============================================
   财务概览 — 仪表盘风格
   ============================================ */
.finance-overview {
  padding: var(--space-xl) var(--space-lg) var(--space-lg);
  position: relative;
  overflow: hidden;
}

.finance-overview-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--gradient-header);
  z-index: 0;
}

.finance-overview-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #0A1628 0%, #1B3A5C 30%, #2D1B69 60%, #1B3A5C 100%);
  background-size: 400% 400%;
  animation: gradientDrift 8s ease-in-out infinite;
  opacity: 0.6;
}

.finance-overview-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    linear-gradient(rgba(0, 229, 255, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 229, 255, 0.04) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  z-index: 1;
  animation: gridPulse 6s ease-in-out infinite;
}

.overview-title {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: var(--space-lg);
  letter-spacing: 1px;
  position: relative;
  z-index: 2;
}

.overview-grid {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 2;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: var(--space-xs);
  letter-spacing: 1px;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 200;
  color: #FFFFFF;
  font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 12rpx rgba(0, 229, 255, 0.4);
}

.overview-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(0, 229, 255, 0.15);
  box-shadow: 0 0 8rpx rgba(0, 229, 255, 0.1);
}

/* ============================================
   图表
   ============================================ */
.chart-placeholder {
  padding: var(--space-md) 0;
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  height: 240rpx;
  gap: 48rpx;
  padding: 0 40rpx;
}

.bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.bar {
  width: 40rpx;
  border-radius: var(--radius-xs) var(--radius-xs) 0 0;
  transition: height 0.5s ease;
  position: relative;
}

.bar-income {
  background: linear-gradient(180deg, #00E676 0%, #00C853 100%);
  box-shadow: 0 0 12rpx rgba(0, 230, 118, 0.3);
}

.bar-expense {
  background: linear-gradient(180deg, #FF5252 0%, #D32F2F 100%);
  box-shadow: 0 0 12rpx rgba(255, 82, 82, 0.3);
}

.bar-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: var(--space-lg);
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  font-size: 24rpx;
  color: var(--text-secondary);
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
}

.dot-income {
  background: var(--success);
  box-shadow: 0 0 8rpx rgba(0, 230, 118, 0.4);
}

.dot-expense {
  background: var(--error);
  box-shadow: 0 0 8rpx rgba(255, 82, 82, 0.4);
}

/* ============================================
   区块标题
   ============================================ */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg) var(--space-lg) 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.2px;
}

.section-action {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

/* ============================================
   财务卡片
   ============================================ */
.finance-card {
  margin: var(--space-sm) var(--space-lg);
}

.finance-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.finance-month {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.finance-card-body {
  display: flex;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.finance-stat {
  flex: 1;
}

.finance-stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 4rpx;
  letter-spacing: 0.5px;
}

.finance-stat-value {
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
  font-variant-numeric: tabular-nums;
}

.text-income {
  color: var(--success);
  text-shadow: 0 0 8rpx rgba(0, 230, 118, 0.3);
}

.text-expense {
  color: var(--error);
  text-shadow: 0 0 8rpx rgba(255, 82, 82, 0.3);
}

.finance-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}

.finance-meta {
  font-size: 24rpx;
  color: var(--text-disabled);
}

.finance-action {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
}

/* ============================================
   公告项
   ============================================ */
.announce-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-xs);
}

.announce-item:last-child {
  border-bottom: none;
}

.announce-badge {
  font-size: 20rpx;
  color: var(--warning);
  background: var(--warning-light);
  border: 1rpx solid rgba(255, 215, 64, 0.2);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-xs);
  font-weight: 600;
  letter-spacing: 0.5px;
  text-shadow: 0 0 8rpx rgba(255, 215, 64, 0.3);
}

.announce-title {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.announce-meta {
  width: 100%;
  font-size: 22rpx;
  color: var(--text-disabled);
}
