/* pages/finance/detail/detail.wxss — 深空科技风格 */

.page-finance-detail {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

/* 月份头部 — 深空渐变 */
.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg);
  background: linear-gradient(135deg, #0A1628 0%, #1B3A5C 50%, #2D1B69 100%);
  color: #FFFFFF;
}

.detail-month {
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: -0.3px;
}

/* 收支总览 — 仪表盘 */
.summary-grid {
  display: flex;
  gap: var(--space-md);
  margin-bottom: 20rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
}

.summary-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-xs);
  letter-spacing: 0.5px;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 200;
  font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
  font-variant-numeric: tabular-nums;
}

.text-income {
  color: var(--success);
  text-shadow: 0 0 10rpx rgba(0, 230, 118, 0.3);
}

.text-expense {
  color: var(--error);
  text-shadow: 0 0 10rpx rgba(255, 82, 82, 0.3);
}

.summary-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--text-disabled);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}

/* 分类列表 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.category-item {
  padding: var(--space-sm) 0;
}

.category-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-xs);
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.category-count {
  font-size: 22rpx;
  color: var(--text-disabled);
}

.category-amount {
  font-size: 28rpx;
  font-weight: 700;
  font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
  font-variant-numeric: tabular-nums;
}

.category-bar-bg {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 4rpx;
  overflow: hidden;
}

.category-bar-fill {
  height: 100%;
  background: var(--gradient-progress);
  border-radius: 4rpx;
  transition: width 0.5s ease;
  box-shadow: 0 0 6rpx rgba(0, 229, 255, 0.2);
}

/* 饼图占位 */
.pie-chart-placeholder {
  display: flex;
  justify-content: center;
  padding: var(--space-lg) 0 var(--space-sm);
}

.pie-chart {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: conic-gradient(var(--success) 0% 80%, var(--warning) 80% 86%, var(--accent) 86% 92%, var(--primary) 92% 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 0 24rpx rgba(0, 229, 255, 0.15);
}

.pie-center {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-card-solid);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.pie-total {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--primary);
}

.pie-label {
  font-size: 18rpx;
  color: var(--text-secondary);
}

/* 流水明细 */
.detail-list {
  display: flex;
  flex-direction: column;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--border);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex: 1;
  min-width: 0;
}

.detail-type {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
  flex-shrink: 0;
}

.income-dot {
  background: var(--success);
  box-shadow: 0 0 8rpx rgba(0, 230, 118, 0.3);
}

.expense-dot {
  background: var(--error);
  box-shadow: 0 0 8rpx rgba(255, 82, 82, 0.3);
}

.detail-desc {
  min-width: 0;
}

.detail-category {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.detail-note {
  font-size: 22rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.detail-amount {
  font-size: 28rpx;
  font-weight: 700;
  font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
  font-variant-numeric: tabular-nums;
  flex-shrink: 0;
  margin-left: var(--space-sm);
}
