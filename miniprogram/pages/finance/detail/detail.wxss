/* pages/finance/detail/detail.wxss */

.page-finance-detail {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: var(--space-md) var(--space-lg) 0;
  padding: 34rpx var(--space-lg);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  box-shadow: var(--shadow-lg), var(--shadow-inset);
}

.detail-month {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.summary-grid {
  display: flex;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.summary-item {
  flex: 1;
  padding: 22rpx 18rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  text-align: center;
}

.summary-label {
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.summary-value {
  font-size: 34rpx;
  font-weight: 600;
}

.summary-meta {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(152, 162, 179, 0.14);
  font-size: 22rpx;
  color: var(--text-secondary);
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.category-item {
  position: relative;
}

.category-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.category-count {
  font-size: 22rpx;
  color: var(--text-muted);
}

.category-amount {
  margin-bottom: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.category-bar-bg {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.18);
  box-shadow: inset 0 2rpx 5rpx rgba(148, 163, 184, 0.14);
  overflow: hidden;
}

.category-bar-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-progress);
}

.pie-chart-placeholder {
  display: flex;
  justify-content: center;
  padding: 28rpx 0 8rpx;
}

.pie-chart {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: conic-gradient(#9CB3A5 0% 34%, #AAB8C7 34% 58%, #D0B087 58% 80%, #C99B97 80% 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.08);
}

.pie-center {
  width: 122rpx;
  height: 122rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #FFFFFF 0%, #F4F6F8 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.pie-total {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.pie-label {
  font-size: 18rpx;
  color: var(--text-secondary);
}

.detail-list {
  display: flex;
  flex-direction: column;
}

.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(152, 162, 179, 0.14);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.detail-type {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-inverse);
  flex-shrink: 0;
}

.income-dot {
  background: var(--success);
}

.expense-dot {
  background: var(--error);
}

.detail-desc {
  flex: 1;
  min-width: 0;
}

.detail-category {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.detail-note {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.detail-amount {
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

/* 附件列表 */
.attachment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.attachment-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-sm);
  background: rgba(248, 250, 252, 0.8);
}

.attachment-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.attachment-info {
  flex: 1;
  min-width: 0;
}

.attachment-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.attachment-size {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.attachment-arrow {
  font-size: 32rpx;
  color: var(--text-disabled);
  flex-shrink: 0;
}

/* 底部分享 */
.share-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx var(--space-lg);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(251, 251, 252, 0.92);
  backdrop-filter: blur(16rpx);
  border-top: 1rpx solid rgba(152, 162, 179, 0.16);
}

.share-btn {
  width: 100%;
  height: 88rpx;
  border: none;
  border-radius: var(--radius-sm);
  background: var(--gradient-primary);
  color: var(--text-inverse);
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 28rpx rgba(102, 125, 150, 0.22);
}

.share-btn::after {
  border: none;
}
