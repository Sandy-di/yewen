/* pages/mine/settings/settings.wxss */

.page-settings {
  min-height: 100vh;
  background: var(--bg-page);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(152, 162, 179, 0.14);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.setting-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.setting-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
}
