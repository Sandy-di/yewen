/* pages/mine/role-switch/role-switch.wxss */

.page-role-switch {
  min-height: 100vh;
  background: var(--bg-page);
}

.switch-notice {
  padding: 22rpx 24rpx;
  margin-bottom: var(--space-lg);
  border: 1rpx solid rgba(194, 154, 99, 0.16);
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #FFFFFF 0%, #FBF5EC 100%);
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--warning);
  box-shadow: var(--shadow-sm);
}

.notice-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  display: block;
}

.current-identity {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: var(--space-md);
  background: var(--primary-light);
  border-radius: var(--radius-sm);
}

.current-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.current-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary-strong);
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.role-active {
  border-color: rgba(102, 125, 150, 0.22);
  box-shadow: 0 14rpx 28rpx rgba(102, 125, 150, 0.10), inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.role-icon {
  font-size: 48rpx;
  line-height: 1;
}

.role-info {
  flex: 1;
}

.role-name {
  margin-bottom: 6rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.role-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.role-check {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary-strong);
}

.switch-btn {
  font-size: 24rpx !important;
  padding: 0 24rpx !important;
  height: 56rpx !important;
  line-height: 56rpx !important;
  background: var(--primary-light) !important;
  color: var(--primary-strong) !important;
  border: none !important;
  border-radius: var(--radius-sm) !important;
}

.tips-section {
  margin-top: var(--space-xl);
  padding: 24rpx;
  background: #fff;
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-sm);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}
