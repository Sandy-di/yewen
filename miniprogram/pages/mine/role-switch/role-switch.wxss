/* pages/mine/role-switch/role-switch.wxss */

.page-role-switch {
  min-height: 100vh;
  background: var(--bg-page);
}

/* 当前身份横幅 */
.current-banner {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: var(--space-lg);
  padding: 32rpx var(--space-lg);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  border: 1rpx solid rgba(102, 125, 150, 0.18);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md), var(--shadow-inset);
}

.current-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  border-radius: var(--radius-md);
  background: var(--primary-light);
  flex-shrink: 0;
}

.current-info {
  flex: 1;
}

.current-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.current-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary-strong);
}

/* 切换区域 */
.switch-section {
  margin: 0 var(--space-lg);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: var(--space-md);
  padding-left: 4rpx;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-md);
  background: var(--bg-card);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.role-card:active {
  transform: scale(0.98);
}

.role-active {
  border-color: rgba(102, 125, 150, 0.32);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  box-shadow: var(--shadow-md), inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.role-card-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
}

.role-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-card-muted);
  flex-shrink: 0;
}

.role-active .role-icon {
  background: var(--primary-light);
}

.role-info {
  flex: 1;
  min-width: 0;
}

.role-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.role-desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--primary-light);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary-strong);
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--primary);
}

.role-switch-hint {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--bg-card-muted);
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 加载条 */
.role-loading {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--bg-card-muted);
}

.loading-bar {
  height: 100%;
  width: 40%;
  background: var(--primary);
  border-radius: 2rpx;
  animation: loading-slide 1s ease-in-out infinite;
}

@keyframes loading-slide {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(350%); }
}

/* 提示区域 */
.tips-section {
  margin: var(--space-xl) var(--space-lg);
  padding: 24rpx;
  background: var(--bg-card);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-xs);
}

.tips-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.tips-note {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.12);
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
}
