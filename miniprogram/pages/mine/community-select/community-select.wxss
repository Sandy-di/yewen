/* pages/mine/community-select/community-select.wxss */
.page-community-select {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

.search-clear {
  font-size: 28rpx;
  color: #9CA3AF;
  padding: 4rpx 8rpx;
}

.search-btn {
  background: #4A6FA5;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 28rpx;
  border-radius: 16rpx;
  line-height: 1.4;
  border: none;
}

.search-btn::after {
  border: none;
}

.result-area {
  padding: 0;
}

.loading-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #6B7280;
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #6B7280;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #9CA3AF;
}

.community-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.community-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: transform 0.15s;
}

.community-item:active {
  transform: scale(0.98);
}

.community-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.community-address {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.community-meta {
  font-size: 24rpx;
  color: #9CA3AF;
}
