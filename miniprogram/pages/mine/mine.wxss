/* pages/mine/mine.wxss */

.page-mine {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(124rpx + env(safe-area-inset-bottom));
}

.user-header {
  position: relative;
  overflow: hidden;
  margin: var(--space-md) var(--space-lg) 0;
  padding: 38rpx var(--space-lg);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  box-shadow: var(--shadow-lg), var(--shadow-inset);
}

.user-header-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(102, 125, 150, 0.16) 0%, rgba(102, 125, 150, 0) 46%);
}

.user-header-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(148, 163, 184, 0.08) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  opacity: 0.28;
}

.user-info {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #FFFFFF 0%, #EFF3F7 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: var(--shadow-md), inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--primary-strong);
}

.user-detail {
  flex: 1;
}

.user-name {
  margin-bottom: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.user-role {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.role-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(102, 125, 150, 0.12);
  color: var(--primary-strong);
  font-size: 22rpx;
}

.role-tag-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary);
}

.verify-tag {
  display: inline-flex;
  align-items: center;
  min-height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.verify-l1 {
  color: var(--success);
  background: var(--success-soft);
}

.verify-l2 {
  color: var(--primary-strong);
  background: rgba(102, 125, 150, 0.12);
}

.verify-l3 {
  color: var(--accent);
  background: var(--accent-soft);
}

.verify-l4 {
  color: var(--error);
  background: var(--error-soft);
}

.property-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.property-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F8FA 100%);
}

.property-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.property-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.property-area {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(152, 162, 179, 0.14);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  margin-right: 20rpx;
  text-align: center;
  font-size: 34rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
}

.community-info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 14rpx 0;
}

.community-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.community-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: var(--text-primary);
}
