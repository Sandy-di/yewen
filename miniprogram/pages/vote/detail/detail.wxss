/* pages/vote/detail/detail.wxss */

.page-vote-detail {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.vote-header {
  position: relative;
  overflow: hidden;
  margin: var(--space-md) var(--space-lg) 0;
  padding: 38rpx var(--space-lg);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg), var(--shadow-inset);
}

.vote-header-active {
  background: linear-gradient(180deg, #FFFFFF 0%, #F3F6FA 100%);
}

.vote-header-ended {
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F7F9 100%);
}

.vote-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(102, 125, 150, 0.14) 0%, rgba(102, 125, 150, 0) 44%);
}

.vote-status-tag,
.vote-title,
.vote-meta {
  position: relative;
  z-index: 1;
}

.vote-status-tag {
  margin-bottom: 16rpx;
}

.vote-title {
  margin-bottom: 14rpx;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.45;
  color: var(--text-primary);
}

.vote-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.meta-divider {
  color: var(--text-muted);
}

.countdown-bar {
  margin: 18rpx var(--space-lg) 0;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(194, 154, 99, 0.16);
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #FFFFFF 0%, #FBF5EC 100%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: var(--shadow-sm);
}

.countdown-icon {
  font-size: 28rpx;
}

.countdown-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--warning);
}

.countdown-deadline {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.vote-description {
  font-size: 28rpx;
  line-height: 1.85;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.vote-time-info {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(152, 162, 179, 0.14);
  font-size: 24rpx;
  color: var(--text-secondary);
}

.progress-section {
  margin-bottom: 28rpx;
}

.progress-section:last-child {
  margin-bottom: 0;
}

.progress-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.progress-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.progress-percent {
  margin-top: 10rpx;
  text-align: right;
  font-size: 24rpx;
  color: var(--primary-strong);
  font-weight: 600;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F9FB 100%);
}

.option-selected {
  border-color: rgba(102, 125, 150, 0.24);
  box-shadow: 0 12rpx 26rpx rgba(102, 125, 150, 0.10);
}

.option-disabled {
  opacity: 0.92;
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(152, 162, 179, 0.34);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.option-selected .option-radio {
  border-color: var(--primary);
}

.radio-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.radio-checked {
  background: var(--primary);
}

.option-content {
  flex: 1;
}

.option-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.option-result {
  margin-top: 16rpx;
}

.result-bar-bg {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.18);
  box-shadow: inset 0 2rpx 5rpx rgba(148, 163, 184, 0.14);
  overflow: hidden;
  margin-bottom: 10rpx;
}

.result-bar-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-progress);
}

.result-stats {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.chain-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.chain-hash {
  flex: 1;
  min-width: 0;
}

.chain-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.chain-value {
  font-size: 24rpx;
  color: var(--primary-strong);
  word-break: break-all;
}

.result-summary {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.result-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx var(--space-lg);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(251, 251, 252, 0.92);
  backdrop-filter: blur(16rpx);
  border-top: 1rpx solid rgba(152, 162, 179, 0.16);
  z-index: 50;
}

.confirm-option,
.verify-notice,
.verify-current,
.verify-desc,
.confirm-notice {
  font-size: 26rpx;
  line-height: 1.75;
  color: var(--text-secondary);
}

.confirm-option-label,
.verify-level {
  color: var(--text-primary);
  font-weight: 700;
}

.verify-current {
  margin-top: 16rpx;
}

.verify-desc,
.confirm-notice {
  margin-top: 14rpx;
}

.skeleton-page {
  padding: var(--space-md) var(--space-lg);
}

.share-btn-fix {
  padding: 0;
  margin: 0;
  line-height: inherit;
  background: transparent;
  border: none;
}

.share-btn-fix::after {
  border: none;
}
