/* pages/vote/result/result.wxss */

.page-result {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.result-header {
  position: relative;
  overflow: hidden;
  margin: var(--space-md) var(--space-lg) 0;
  padding: 40rpx var(--space-lg);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-lg);
  text-align: center;
  box-shadow: var(--shadow-lg), var(--shadow-inset);
}

.result-pass {
  background: linear-gradient(180deg, #FFFFFF 0%, #F2F8F4 100%);
}

.result-fail {
  background: linear-gradient(180deg, #FFFFFF 0%, #FAF1F1 100%);
}

.result-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(102, 125, 150, 0.10) 0%, rgba(102, 125, 150, 0) 52%);
}

.result-badge,
.result-title,
.result-vote-name {
  position: relative;
  z-index: 1;
}

.result-badge {
  margin-bottom: 14rpx;
  font-size: 76rpx;
  line-height: 1;
}

.result-title {
  margin-bottom: 12rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.result-vote-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.stats-grid {
  display: flex;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.stat-box {
  flex: 1;
  padding: 22rpx 18rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  text-align: center;
}

.stat-value {
  margin-bottom: 8rpx;
  font-size: 52rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.stat-label {
  margin-bottom: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.stat-detail {
  font-size: 22rpx;
  color: var(--text-muted);
}

.standard-compare {
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(152, 162, 179, 0.14);
}

.compare-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 12rpx 0;
}

.compare-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.compare-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.compare-pass {
  color: var(--success);
}

.compare-fail {
  color: var(--error);
}

.result-options {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.result-option-item {
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid rgba(152, 162, 179, 0.14);
}

.result-option-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.result-option-header,
.result-option-detail,
.chain-info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.result-option-header {
  margin-bottom: 12rpx;
}

.result-option-label {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.result-option-percent {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary-strong);
}

.result-option-bar {
  height: 14rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.18);
  box-shadow: inset 0 2rpx 5rpx rgba(148, 163, 184, 0.14);
  overflow: hidden;
}

.result-option-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-progress);
}

.result-option-detail {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.chain-info-row {
  align-items: flex-start;
  padding: 12rpx 0;
}

.chain-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.chain-hash,
.chain-value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-primary);
  word-break: break-all;
}

.chain-hash {
  color: var(--primary-strong);
}

.chain-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(152, 162, 179, 0.14);
}

.chain-actions .btn {
  flex: 1;
}

.result-summary-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.bottom-actions-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx var(--space-lg);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(251, 251, 252, 0.92);
  backdrop-filter: blur(16rpx);
  border-top: 1rpx solid rgba(152, 162, 179, 0.16);
  z-index: 50;
}

.bottom-actions-bar .btn,
.share-btn {
  flex: 1;
}

.share-btn {
  margin: 0;
  padding: 0;
  line-height: 88rpx;
}
