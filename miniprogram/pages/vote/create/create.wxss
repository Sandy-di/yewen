/* pages/vote/create/create.wxss — 深空科技风格 */

.page-vote-create {
  min-height: 100vh;
  background: var(--bg-page);
}

/* 选择器面板 */
.picker-panel {
  margin-top: var(--space-sm);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: rgba(255, 255, 255, 0.02);
}

.picker-option {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  border-bottom: 1rpx solid var(--border);
  transition: background 0.2s;
}

.picker-option:last-child {
  border-bottom: none;
}

.picker-option:active {
  background: rgba(0, 229, 255, 0.04);
}

.picker-option-active {
  background: var(--primary-light);
  border-color: rgba(0, 229, 255, 0.15);
}

.picker-option-main {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: var(--space-sm);
}

.picker-option-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex: 1;
}

.picker-option-check {
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 700;
}

/* 选项表单 */
.options-form-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.option-form-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.option-form-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--primary-light);
  border: 1rpx solid rgba(0, 229, 255, 0.25);
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.option-form-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--bg-input);
  transition: all 0.2s;
}

.option-form-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 12rpx rgba(0, 229, 255, 0.15);
}

.option-form-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-disabled);
  font-size: 28rpx;
  flex-shrink: 0;
}

.add-option-btn {
  margin-top: var(--space-sm);
  padding: 20rpx;
  border: 2rpx dashed rgba(0, 229, 255, 0.3);
  border-radius: var(--radius-sm);
  text-align: center;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.add-option-btn:active {
  border-color: var(--primary);
  background: var(--primary-light);
  box-shadow: 0 0 12rpx rgba(0, 229, 255, 0.15);
}

/* 提交区 */
.submit-section {
  padding: 40rpx 0;
}
