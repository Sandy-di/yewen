/* packageAdmin/pages/work-order/work-order.wxss — 深空科技风格 */
.page-work-order { min-height: 100vh; background: var(--bg-page); }
.page-work-order .tabs-pill-custom { margin: var(--space-md) var(--space-lg); background: rgba(255,255,255,0.04); border: 1rpx solid var(--border); display: flex; border-radius: var(--radius-lg); padding: 6rpx; }
.page-work-order .tab-item { flex: 1; text-align: center; height: 64rpx; line-height: 64rpx; font-size: 26rpx; color: var(--text-secondary); border-radius: var(--radius-md); transition: all 0.25s; }
.page-work-order .tab-item-active { color: #fff; background: var(--gradient-btn); font-weight: 600; box-shadow: var(--glow-primary); }
.order-card { margin-bottom: var(--space-sm); }
.order-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.order-type { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.order-desc { font-size: 26rpx; color: var(--text-secondary); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 12rpx; }
.order-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 12rpx; border-top: 1rpx solid var(--border); }
.order-time { font-size: 22rpx; color: var(--text-disabled); }
