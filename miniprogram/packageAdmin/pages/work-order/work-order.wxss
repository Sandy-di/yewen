/* packageAdmin/pages/work-order/work-order.wxss */

.page-work-order {
  min-height: 100vh;
  background: var(--bg-page);
}

.page-work-order .tabs-pill-custom {
  margin: var(--space-md) var(--space-lg);
}

.order-card {
  margin-bottom: var(--space-md);
}

.order-header {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.order-type {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  color: var(--text-primary);
}

.order-desc {
  margin-bottom: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(152, 162, 179, 0.14);
}

.order-time {
  font-size: 22rpx;
  color: var(--text-secondary);
}
