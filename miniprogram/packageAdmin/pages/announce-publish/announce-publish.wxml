<!-- packageAdmin/pages/announce-publish/announce-publish.wxml -->
<view class="page-announce-publish">
  <view class="container">
    <view class="card">
      <view class="form-group">
        <view class="form-label"><text class="required">*</text> 公告标题</view>
        <input class="form-input" placeholder="请输入公告标题" maxlength="50" value="{{form.title}}" bindinput="onTitleInput" />
      </view>
      <view class="form-group">
        <view class="form-label"><text class="required">*</text> 公告内容</view>
        <textarea class="form-textarea" placeholder="请输入公告内容" maxlength="5000" value="{{form.content}}" bindinput="onContentInput" />
      </view>
    </view>

    <view class="card">
      <view class="form-group">
        <view class="form-label">公告类型</view>
        <view class="type-options">
          <view wx:for="{{typeOptions}}" wx:key="value" class="type-opt {{form.type === item.value ? 'type-opt-active' : ''}}" data-value="{{item.value}}" bindtap="onTypeSelect">{{item.label}}</view>
        </view>
      </view>
      <view class="form-group">
        <view class="setting-item">
          <view class="setting-label">置顶公告</view>
          <switch checked="{{form.isTop}}" bindchange="onTopChange" color="#667D96" />
        </view>
      </view>
    </view>

    <view class="submit-section">
      <view class="btn btn-primary btn-block" bindtap="onSubmit" disabled="{{submitting}}">{{submitting ? '发布中...' : '发布公告'}}</view>
    </view>
  </view>
</view>
