/* packageAdmin/pages/user-manage/user-manage.wxss */

.page-user-manage {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom));
}

.user-card {
  margin-bottom: var(--space-sm);
  padding: var(--space-md) var(--space-lg);
}

.user-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-phone {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(152, 162, 179, 0.14);
}

.user-role-badge {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary-strong);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.user-verified {
  font-size: 22rpx;
  color: var(--success);
  background: var(--success-soft);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
