/* packageAdmin/pages/vote-manage/vote-manage.wxss */

.page-vote-manage {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(124rpx + env(safe-area-inset-bottom));
}

.page-vote-manage .tabs-pill-custom {
  margin: var(--space-md) var(--space-lg);
}

.vote-list {
  padding: 0 var(--space-lg) var(--space-lg);
}

.vote-card {
  margin-bottom: var(--space-md);
}

.vote-header {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.vote-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  color: var(--text-primary);
}

.vote-meta {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}
