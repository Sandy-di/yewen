/* app.wxss - White Neumorphic Design System */

page {
  --primary: #667D96;
  --primary-rgb: 102, 125, 150;
  --primary-strong: #4F647B;
  --primary-soft: rgba(102, 125, 150, 0.12);
  --primary-light: rgba(102, 125, 150, 0.12);

  --accent: #7D8FA2;
  --accent-soft: rgba(125, 143, 162, 0.12);
  --accent-light: rgba(125, 143, 162, 0.12);

  --bg-page: #F4F5F7;
  --bg-layer: #FBFBFC;
  --bg-card: #FFFFFF;
  --bg-card-soft: #F7F8FA;
  --bg-card-muted: #F1F3F6;
  --bg-card-solid: #FFFFFF;
  --bg-input: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  --bg-pressed: #EEF1F4;

  --text-primary: #1F2937;
  --text-secondary: #6B7280;
  --text-muted: #98A2B3;
  --text-disabled: #B1B8C3;
  --text-inverse: #FFFFFF;

  --border: rgba(148, 163, 184, 0.26);
  --border-strong: rgba(107, 114, 128, 0.22);
  --border-soft: rgba(255, 255, 255, 0.96);

  --success: #6F9A7E;
  --success-soft: rgba(111, 154, 126, 0.14);
  --success-light: rgba(111, 154, 126, 0.14);
  --warning: #C29A63;
  --warning-soft: rgba(194, 154, 99, 0.14);
  --warning-light: rgba(194, 154, 99, 0.14);
  --error: #B77C7A;
  --error-soft: rgba(183, 124, 122, 0.14);
  --error-light: rgba(183, 124, 122, 0.14);

  --shadow-xs: 0 4rpx 10rpx rgba(15, 23, 42, 0.04);
  --shadow-sm: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
  --shadow-md: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
  --shadow-lg: 0 24rpx 52rpx rgba(15, 23, 42, 0.08);
  --shadow-inset: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), inset 0 -2rpx 8rpx rgba(148, 163, 184, 0.10);
  --shadow-soft-press: inset 0 4rpx 10rpx rgba(148, 163, 184, 0.12);

  --gradient-surface: linear-gradient(180deg, #FFFFFF 0%, #F7F8FA 100%);
  --gradient-soft: linear-gradient(180deg, #FFFFFF 0%, #F3F5F8 100%);
  --gradient-primary: linear-gradient(135deg, #73879D 0%, #566B82 100%);
  --gradient-success: linear-gradient(135deg, #8DAA97 0%, #6F9A7E 100%);
  --gradient-warning: linear-gradient(135deg, #D4B184 0%, #C29A63 100%);
  --gradient-error: linear-gradient(135deg, #CA9591 0%, #B77C7A 100%);
  --gradient-header: linear-gradient(180deg, #FFFFFF 0%, #F4F6F8 100%);
  --gradient-btn: linear-gradient(135deg, #73879D 0%, #566B82 100%);
  --gradient-progress: linear-gradient(90deg, #AAB8C7 0%, #667D96 100%);
  --glow-primary: 0 10rpx 20rpx rgba(102, 125, 150, 0.12);
  --glow-success: 0 10rpx 20rpx rgba(111, 154, 126, 0.12);
  --glow-error: 0 10rpx 20rpx rgba(183, 124, 122, 0.12);

  --space-2xs: 8rpx;
  --space-xs: 12rpx;
  --space-sm: 20rpx;
  --space-md: 28rpx;
  --space-lg: 36rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;

  --radius-xs: 12rpx;
  --radius-sm: 20rpx;
  --radius-md: 28rpx;
  --radius-lg: 36rpx;
  --radius-xl: 44rpx;

  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  background: var(--bg-page);
}

button,
input,
textarea {
  font-family: inherit;
}

.container {
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom));
  box-sizing: border-box;
  min-height: 100vh;
}

.card {
  position: relative;
  overflow: hidden;
  margin-bottom: var(--space-md);
  padding: var(--space-lg);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
  background: var(--gradient-surface);
  box-shadow: var(--shadow-md), var(--shadow-inset);
}

.card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.75) 0%, rgba(255, 255, 255, 0) 44%);
  pointer-events: none;
}

.card-glow-top {
  border-top-color: rgba(255, 255, 255, 0.98);
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.07), inset 0 2rpx 0 rgba(255, 255, 255, 0.98), inset 0 -2rpx 8rpx rgba(148, 163, 184, 0.08);
}

.card-title {
  position: relative;
  z-index: 1;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.3px;
}

.btn,
button.btn {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 var(--space-lg);
  border: 1rpx solid transparent;
  border-radius: var(--radius-sm);
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.2px;
  transition: all 0.18s ease;
}

.btn::after,
button.btn::after {
  border: none;
}

.btn-primary,
button.btn-primary {
  color: var(--text-inverse);
  background: var(--gradient-primary);
  box-shadow: 0 14rpx 28rpx rgba(102, 125, 150, 0.24);
}

.btn-primary:active,
button.btn-primary:active {
  transform: translateY(1rpx);
  box-shadow: 0 8rpx 18rpx rgba(102, 125, 150, 0.18);
}

.btn-success {
  color: var(--text-inverse);
  background: var(--gradient-success);
  box-shadow: 0 14rpx 28rpx rgba(111, 154, 126, 0.22);
}

.btn-warning {
  color: var(--text-inverse);
  background: var(--gradient-warning);
  box-shadow: 0 14rpx 28rpx rgba(194, 154, 99, 0.22);
}

.btn-error {
  color: var(--text-inverse);
  background: var(--gradient-error);
  box-shadow: 0 14rpx 28rpx rgba(183, 124, 122, 0.22);
}

.btn-ghost,
button.btn-ghost {
  color: var(--primary-strong);
  border-color: rgba(102, 125, 150, 0.18);
  background: var(--gradient-surface);
  box-shadow: var(--shadow-sm), inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.btn-ghost:active,
button.btn-ghost:active {
  background: var(--bg-pressed);
  box-shadow: var(--shadow-xs), var(--shadow-soft-press);
}

.btn-disabled {
  color: var(--text-disabled);
  border-color: rgba(177, 184, 195, 0.28);
  background: linear-gradient(180deg, #F6F7F9 0%, #EFF2F5 100%);
  box-shadow: none;
}

.btn-sm,
button.btn-sm {
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-xs);
  font-size: 26rpx;
}

.btn-block,
button.btn-block {
  width: 100%;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border: 1rpx solid transparent;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.2px;
}

.tag-primary {
  color: var(--primary-strong);
  background: rgba(102, 125, 150, 0.12);
  border-color: rgba(102, 125, 150, 0.15);
}

.tag-success {
  color: var(--success);
  background: var(--success-soft);
  border-color: rgba(111, 154, 126, 0.16);
}

.tag-warning {
  color: var(--warning);
  background: var(--warning-soft);
  border-color: rgba(194, 154, 99, 0.16);
}

.tag-error {
  color: var(--error);
  background: var(--error-soft);
  border-color: rgba(183, 124, 122, 0.16);
}

.tag-grey {
  color: var(--text-secondary);
  background: rgba(152, 162, 179, 0.12);
  border-color: rgba(152, 162, 179, 0.14);
}

.progress-bar {
  position: relative;
  overflow: hidden;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.18);
  box-shadow: inset 0 2rpx 5rpx rgba(148, 163, 184, 0.16);
}

.progress-bar-fill {
  position: relative;
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-progress);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.45);
  transition: width 0.45s ease;
}

.progress-bar-fill::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.35) 52%, rgba(255, 255, 255, 0) 100%);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 128rpx 64rpx;
  text-align: center;
}

.empty-state-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.empty-state-icon-circle {
  width: 140rpx;
  height: 140rpx;
  border: 1rpx solid rgba(152, 162, 179, 0.18);
  border-radius: 50%;
  background: var(--gradient-surface);
  box-shadow: var(--shadow-sm), var(--shadow-inset);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-state-icon-text {
  font-size: 52rpx;
  color: var(--text-muted);
}

.empty-state-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-state-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 32rpx;
}

.divider {
  height: 1rpx;
  margin: var(--space-md) 0;
  background: rgba(152, 162, 179, 0.18);
}

.divider-glow {
  height: 1rpx;
  margin: var(--space-md) 0;
  background: linear-gradient(90deg, rgba(152, 162, 179, 0) 0%, rgba(152, 162, 179, 0.34) 50%, rgba(152, 162, 179, 0) 100%);
}

.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(152, 162, 179, 0.16);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-label {
  min-width: 160rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.list-item-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-group {
  margin-bottom: var(--space-lg);
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.form-label .required {
  margin-right: 8rpx;
  color: var(--error);
}

.form-input,
.form-textarea,
.form-picker {
  width: 100%;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
  background: var(--bg-input);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
  color: var(--text-primary);
}

.form-input {
  height: 92rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.form-textarea {
  min-height: 220rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
}

.form-picker {
  height: 92rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-input:focus,
.form-textarea:focus {
  border-color: rgba(102, 125, 150, 0.3);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95), 0 0 0 6rpx rgba(102, 125, 150, 0.08);
}

.form-picker-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-picker-placeholder {
  color: var(--text-muted);
}

.form-picker-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
}

.form-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.form-error {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--error);
}

.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.upload-item {
  position: relative;
  overflow: hidden;
  width: 160rpx;
  height: 160rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: var(--radius-sm);
  background: var(--gradient-surface);
  box-shadow: var(--shadow-sm), var(--shadow-inset);
}

.upload-item image {
  width: 100%;
  height: 100%;
}

.upload-add {
  width: 160rpx;
  height: 160rpx;
  border: 1rpx dashed rgba(102, 125, 150, 0.28);
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #FFFFFF 0%, #F4F6F8 100%);
  box-shadow: var(--shadow-sm), inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--primary-strong);
  font-size: 24rpx;
}

.upload-add:active {
  background: var(--bg-pressed);
}

.upload-add-icon {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.upload-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(31, 41, 55, 0.7);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.timeline {
  padding-left: 36rpx;
}

.timeline-item {
  position: relative;
  padding: 0 0 var(--space-lg) var(--space-lg);
  border-left: 2rpx solid rgba(152, 162, 179, 0.18);
}

.timeline-item:last-child {
  padding-bottom: 0;
  border-left-color: transparent;
}

.timeline-dot {
  position: absolute;
  top: 8rpx;
  left: -12rpx;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #F4F5F7;
  border-radius: 50%;
  background: #C4CBD5;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.72);
}

.timeline-dot-active {
  background: var(--primary);
}

.timeline-dot-success {
  background: var(--success);
}

.timeline-time {
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.timeline-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
}

.search-bar {
  display: flex;
  align-items: center;
  height: 84rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FA 100%);
  box-shadow: var(--shadow-sm), var(--shadow-inset);
}

.search-bar-icon {
  margin-right: 12rpx;
  font-size: 26rpx;
  color: var(--text-muted);
}

.search-bar-placeholder,
.search-bar-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.tabs {
  display: flex;
  padding: 0 var(--space-md);
  border-bottom: 1rpx solid rgba(152, 162, 179, 0.16);
  background: transparent;
}

.tab-item {
  position: relative;
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.16s ease;
}

.tab-item-active {
  font-weight: 600;
  color: var(--text-primary);
}

.tab-item-active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  width: 44rpx;
  height: 6rpx;
  border-radius: 999rpx;
  transform: translateX(-50%);
  background: var(--primary);
}

.tabs-pill {
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  margin-bottom: var(--space-md);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #FCFCFD 0%, #F0F3F6 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.tabs-pill .tab-item {
  height: 68rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.tabs-pill .tab-item-active {
  color: var(--text-inverse);
  background: var(--gradient-primary);
  box-shadow: 0 10rpx 20rpx rgba(102, 125, 150, 0.18);
}

.tabs-pill .tab-item-active::after {
  display: none;
}

.fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(144rpx + env(safe-area-inset-bottom));
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--gradient-primary);
  color: var(--text-inverse);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  box-shadow: 0 20rpx 34rpx rgba(102, 125, 150, 0.24);
  z-index: 100;
}

.fab:active {
  transform: translateY(2rpx);
}

.skeleton {
  border-radius: var(--radius-xs);
  background: linear-gradient(90deg, rgba(226, 232, 240, 0.85) 25%, rgba(255, 255, 255, 0.95) 50%, rgba(226, 232, 240, 0.85) 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease infinite;
}

.glow-number {
  font-family: "SF Mono", "Menlo", "Monaco", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
  color: var(--text-primary);
  letter-spacing: -0.2px;
}

.stat-card {
  padding: var(--space-lg);
  text-align: center;
}

.stat-value {
  font-family: "SF Mono", "Menlo", "Monaco", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
  font-size: 54rpx;
  font-weight: 500;
  line-height: 1.15;
  color: var(--text-primary);
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  letter-spacing: 0.8px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg) var(--space-lg) 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.2px;
}

.section-action {
  font-size: 26rpx;
  color: var(--primary-strong);
}

.text-income {
  color: var(--success);
}

.text-expense {
  color: var(--error);
}

.page-header {
  position: relative;
  overflow: hidden;
  margin: var(--space-md) var(--space-lg) 0;
  padding: 40rpx var(--space-lg);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F8FA 100%);
  box-shadow: var(--shadow-lg), var(--shadow-inset);
}

.page-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(102, 125, 150, 0.12) 0%, rgba(102, 125, 150, 0) 48%);
}

.page-header-title,
.page-header-desc {
  position: relative;
  z-index: 1;
}

.page-header-title {
  margin-bottom: 8rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.page-header-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  background: rgba(244, 245, 247, 0.78);
  backdrop-filter: blur(16rpx);
}

.modal-content {
  width: 100%;
  max-width: 640rpx;
  overflow: hidden;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 36rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F8F9FB 100%);
  box-shadow: 0 30rpx 60rpx rgba(15, 23, 42, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.modal-title {
  padding: 36rpx 32rpx 0;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
}

.modal-body {
  padding: 24rpx 32rpx 32rpx;
  color: var(--text-secondary);
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
}

.modal-btn {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
}

.modal-btn-cancel {
  color: var(--text-secondary);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  background: var(--gradient-surface);
  box-shadow: var(--shadow-sm), inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
}

.modal-btn-confirm {
  color: var(--text-inverse);
  background: var(--gradient-primary);
  box-shadow: 0 12rpx 22rpx rgba(102, 125, 150, 0.22);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(152, 162, 179, 0.14);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.setting-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.setting-arrow {
  padding-left: var(--space-sm);
  font-size: 28rpx;
  color: var(--text-muted);
}

.fade-in {
  animation: fadeIn 0.45s ease both;
}

.fade-in-up {
  animation: fadeInUp 0.55s ease both;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(14rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes skeleton-loading {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}
