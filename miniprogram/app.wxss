/* app.wxss - 深空科技设计系统 */

/* ============================================
   设计令牌 — 深空科技色彩体系
   ============================================ */
page {
  /* 主色系 */
  --primary: #00E5FF;
  --primary-rgb: 0, 229, 255;
  --primary-light: rgba(0, 229, 255, 0.12);
  --primary-dark: #00B8D4;

  /* 强调色 */
  --accent: #7C4DFF;
  --accent-rgb: 124, 77, 255;
  --accent-light: rgba(124, 77, 255, 0.12);

  /* 背景色系 */
  --bg-page: #0D1B2A;
  --bg-card: rgba(255, 255, 255, 0.06);
  --bg-card-solid: #1B2838;
  --bg-elevated: rgba(255, 255, 255, 0.10);
  --bg-input: rgba(255, 255, 255, 0.05);

  /* 文字色系 */
  --text-primary: #E8EDF5;
  --text-secondary: #8899AA;
  --text-disabled: #4A5568;
  --text-inverse: #0D1B2A;

  /* 边框/分割线 */
  --border: rgba(255, 255, 255, 0.08);
  --border-light: rgba(255, 255, 255, 0.04);
  --border-focus: rgba(0, 229, 255, 0.5);

  /* 功能色 */
  --success: #00E676;
  --success-light: rgba(0, 230, 118, 0.12);
  --warning: #FFD740;
  --warning-light: rgba(255, 215, 64, 0.12);
  --error: #FF5252;
  --error-light: rgba(255, 82, 82, 0.12);

  /* 发光效果 */
  --glow-primary: 0 0 20rpx rgba(0, 229, 255, 0.30);
  --glow-accent: 0 0 20rpx rgba(124, 77, 255, 0.30);
  --glow-success: 0 0 16rpx rgba(0, 230, 118, 0.30);
  --glow-error: 0 0 16rpx rgba(255, 82, 82, 0.30);

  /* 阴影/发光层级 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 229, 255, 0.08);
  --shadow-md: 0 4rpx 24rpx rgba(0, 229, 255, 0.15);
  --shadow-lg: 0 8rpx 40rpx rgba(0, 229, 255, 0.25);
  --shadow-glow: 0 0 30rpx rgba(0, 229, 255, 0.35);

  /* 渐变 */
  --gradient-header: linear-gradient(135deg, #0A1628 0%, #1B3A5C 50%, #2D1B69 100%);
  --gradient-btn: linear-gradient(135deg, #00E5FF 0%, #7C4DFF 100%);
  --gradient-progress: linear-gradient(90deg, #00E5FF 0%, #7C4DFF 100%);

  /* 间距令牌 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;

  /* 圆角令牌 */
  --radius-xs: 4rpx;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;

  /* 字体 */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-page);
  line-height: 1.6;
}

/* ============================================
   通用容器
   ============================================ */
.container {
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

/* ============================================
   毛玻璃卡片
   ============================================ */
.card {
  background: var(--bg-card-solid);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-sm);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  position: relative;
  overflow: hidden;
}

/* 毛玻璃卡片 — 全局扫光效果（hover态通过JS切换class） */
.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -200%;
  width: 200%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(0, 229, 255, 0.04) 45%, rgba(0, 229, 255, 0.08) 50%, rgba(0, 229, 255, 0.04) 55%, transparent 100%);
  background-size: 200% 100%;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.card-sweep::before {
  opacity: 1;
  animation: hologramSweep 0.8s ease forwards;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  letter-spacing: -0.2px;
}

/* 带发光装饰线的卡片 */
.card-glow-top {
  border-top: 2rpx solid transparent;
  background-image: linear-gradient(var(--bg-card-solid), var(--bg-card-solid)), var(--gradient-btn);
  background-origin: border-box;
  background-clip: padding-box, border-box;
}

/* ============================================
   按钮
   ============================================ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.5px;
  border: none;
  transition: all 0.15s ease;
  position: relative;
  overflow: hidden;
}

.btn::after {
  border: none;
}

/* 主按钮 — 电光青渐变 */
.btn-primary {
  background: var(--gradient-btn);
  color: #FFFFFF;
  box-shadow: var(--glow-primary);
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 0 40rpx rgba(0, 229, 255, 0.50);
}

/* 全息扫光叠加 */
.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s ease;
}

.btn-primary:active::before {
  left: 100%;
}

.btn-success {
  background: var(--success);
  color: var(--text-inverse);
  box-shadow: var(--glow-success);
}

.btn-warning {
  background: var(--warning);
  color: var(--text-inverse);
}

.btn-error {
  background: var(--error);
  color: #FFFFFF;
  box-shadow: var(--glow-error);
}

/* 幽灵按钮 — 发光边框 */
.btn-ghost {
  background: transparent;
  color: var(--primary);
  border: 1rpx solid rgba(0, 229, 255, 0.4);
}

.btn-ghost:active {
  background: var(--primary-light);
  border-color: var(--primary);
  box-shadow: var(--glow-primary);
}

.btn-disabled {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-disabled);
  border: 1rpx solid var(--border);
}

.btn-sm {
  height: 64rpx;
  font-size: 26rpx;
  padding: 0 var(--space-md);
  border-radius: var(--radius-sm);
}

.btn-block {
  width: 100%;
}

/* ============================================
   标签
   ============================================ */
.tag {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 var(--space-sm);
  border-radius: var(--radius-xs);
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.5px;
  border: 1rpx solid transparent;
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary);
  border-color: rgba(0, 229, 255, 0.2);
}

.tag-success {
  background: var(--success-light);
  color: var(--success);
  border-color: rgba(0, 230, 118, 0.2);
}

.tag-warning {
  background: var(--warning-light);
  color: var(--warning);
  border-color: rgba(255, 215, 64, 0.2);
}

.tag-error {
  background: var(--error-light);
  color: var(--error);
  border-color: rgba(255, 82, 82, 0.2);
}

.tag-grey {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-secondary);
  border-color: var(--border);
}

/* 发光徽章标签 */
.tag-glow {
  box-shadow: var(--glow-primary);
  text-shadow: 0 0 8rpx rgba(0, 229, 255, 0.5);
}

/* ============================================
   进度条 — 流动发光
   ============================================ */
.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 6rpx;
  overflow: hidden;
  position: relative;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  background: var(--gradient-progress);
  transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
  box-shadow: 0 0 12rpx rgba(0, 229, 255, 0.4);
}

/* 进度条内流动光效 */
.progress-bar-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.3) 50%, transparent 100%);
  background-size: 200% 100%;
  animation: progressFlow 1.5s linear infinite;
}

/* ============================================
   空状态
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--space-lg);
  opacity: 0.3;
}

.empty-state-title {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
  font-weight: 500;
}

.empty-state-desc {
  font-size: 26rpx;
  color: var(--text-disabled);
  margin-bottom: 40rpx;
  text-align: center;
}

/* ============================================
   分割线
   ============================================ */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: var(--space-md) 0;
}

/* 发光分割线 */
.divider-glow {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(0, 229, 255, 0.3) 50%, transparent 100%);
  margin: var(--space-md) 0;
}

/* ============================================
   列表项
   ============================================ */
.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  min-width: 160rpx;
}

.list-item-value {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
  text-align: right;
}

/* ============================================
   表单样式 — 暗色科技
   ============================================ */
.form-group {
  margin-bottom: var(--space-lg);
}

.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  font-weight: 500;
}

.form-label .required {
  color: var(--error);
  margin-right: var(--space-xs);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--space-md);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
  background: var(--bg-input);
  color: var(--text-primary);
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 16rpx rgba(0, 229, 255, 0.15);
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: var(--space-md);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
  background: var(--bg-input);
  color: var(--text-primary);
  line-height: 1.6;
  transition: all 0.2s ease;
}

.form-textarea:focus {
  border-color: var(--primary);
  box-shadow: 0 0 16rpx rgba(0, 229, 255, 0.15);
}

.form-hint {
  font-size: 24rpx;
  color: var(--text-disabled);
  margin-top: var(--space-xs);
}

.form-error {
  font-size: 24rpx;
  color: var(--error);
  margin-top: var(--space-xs);
}

/* picker样式 */
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 var(--space-md);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  background: var(--bg-input);
}

.form-picker-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-picker-placeholder {
  font-size: 28rpx;
  color: var(--text-disabled);
}

.form-picker-arrow {
  font-size: 24rpx;
  color: var(--text-disabled);
}

/* ============================================
   上传区域
   ============================================ */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.upload-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
  border: 1rpx solid var(--border);
}

.upload-item image {
  width: 100%;
  height: 100%;
}

.upload-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed rgba(0, 229, 255, 0.3);
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  font-size: 24rpx;
  background: var(--bg-input);
  transition: all 0.2s ease;
}

.upload-add:active {
  border-color: var(--primary);
  box-shadow: 0 0 16rpx rgba(0, 229, 255, 0.15);
  background: var(--primary-light);
}

.upload-add-icon {
  font-size: 48rpx;
  margin-bottom: var(--space-xs);
}

.upload-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 82, 82, 0.8);
  color: #fff;
  border-radius: 0 0 0 var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* ============================================
   时间线 — 发光节点
   ============================================ */
.timeline {
  padding-left: 40rpx;
}

.timeline-item {
  position: relative;
  padding-bottom: var(--space-lg);
  padding-left: var(--space-lg);
  border-left: 2rpx solid var(--border);
}

.timeline-item:last-child {
  border-left-color: transparent;
}

.timeline-dot {
  position: absolute;
  left: -11rpx;
  top: 6rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--text-disabled);
  border: 2rpx solid var(--bg-card-solid);
}

.timeline-dot-active {
  background: var(--primary);
  box-shadow: var(--glow-primary);
}

.timeline-dot-success {
  background: var(--success);
  box-shadow: var(--glow-success);
}

.timeline-time {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-xs);
}

.timeline-content {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* ============================================
   搜索框
   ============================================ */
.search-bar {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: var(--bg-input);
  border-radius: 36rpx;
  padding: 0 var(--space-md);
  margin-bottom: var(--space-md);
  border: 1rpx solid var(--border);
  transition: all 0.2s ease;
}

.search-bar:focus-within {
  border-color: rgba(0, 229, 255, 0.4);
  box-shadow: 0 0 12rpx rgba(0, 229, 255, 0.10);
}

.search-bar-icon {
  font-size: 28rpx;
  color: var(--text-disabled);
  margin-right: 12rpx;
}

.search-bar-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* ============================================
   Tab切换 — 药丸式发光
   ============================================ */
.tabs {
  display: flex;
  background: var(--bg-card-solid);
  border-bottom: 1rpx solid var(--border);
  padding: 0 var(--space-md);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
  transition: color 0.2s ease;
}

.tab-item-active {
  color: var(--primary);
  font-weight: 600;
}

/* 发光指示器 */
.tab-item-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--primary);
  border-radius: 3rpx;
  box-shadow: 0 0 12rpx rgba(0, 229, 255, 0.5);
}

/* 药丸式Tab */
.tabs-pill {
  display: flex;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin-bottom: var(--space-md);
}

.tabs-pill .tab-item {
  flex: 1;
  height: 64rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  transition: all 0.25s ease;
}

.tabs-pill .tab-item-active {
  background: var(--gradient-btn);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: var(--glow-primary);
}

.tabs-pill .tab-item-active::after {
  display: none;
}

/* ============================================
   悬浮按钮 — 脉冲呼吸
   ============================================ */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--gradient-btn);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 229, 255, 0.35);
  z-index: 100;
  animation: fabPulse 3s ease-in-out infinite;
}

.fab:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 48rpx rgba(0, 229, 255, 0.50);
}

/* ============================================
   骨架屏
   ============================================ */
.skeleton {
  background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease infinite;
  border-radius: var(--radius-sm);
}

/* ============================================
   发光数字 — 仪表盘风格
   ============================================ */
.glow-number {
  font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
  font-variant-numeric: tabular-nums;
  color: var(--primary);
  text-shadow: 0 0 12rpx rgba(0, 229, 255, 0.5);
}

.stat-card {
  text-align: center;
  padding: var(--space-lg);
}

.stat-value {
  font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
  font-variant-numeric: tabular-nums;
  font-size: 56rpx;
  font-weight: 200;
  color: var(--primary);
  text-shadow: 0 0 16rpx rgba(0, 229, 255, 0.4);
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: var(--space-xs);
  letter-spacing: 1px;
}

/* ============================================
   网格纹理装饰
   ============================================ */
.grid-pattern {
  background-image:
    linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
}

/* ============================================
   页面头部 — 深空渐变
   ============================================ */
.page-header {
  background: var(--gradient-header);
  padding: var(--space-xl) var(--space-lg) var(--space-lg);
  position: relative;
  overflow: hidden;
}

/* 头部渐变漂移动画 */
.page-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #0A1628 0%, #1B3A5C 30%, #2D1B69 60%, #1B3A5C 100%);
  background-size: 400% 400%;
  animation: gradientDrift 8s ease-in-out infinite;
  opacity: 0.6;
}

/* 头部网格纹理 */
.page-header::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    linear-gradient(rgba(0, 229, 255, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 229, 255, 0.04) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  animation: gridPulse 6s ease-in-out infinite;
}

.page-header-title,
.page-header-desc {
  position: relative;
  z-index: 1;
}

.page-header-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: -0.5px;
  margin-bottom: var(--space-xs);
}

.page-header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ============================================
   动画关键帧
   ============================================ */

/* 入场动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

/* 交错入场 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in-up {
  animation: fadeInUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
}

/* 全息扫光 */
@keyframes hologramSweep {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 渐变漂移 */
@keyframes gradientDrift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

/* 网格脉冲 */
@keyframes gridPulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* FAB脉冲呼吸 */
@keyframes fabPulse {
  0%, 100% { box-shadow: 0 8rpx 32rpx rgba(0, 229, 255, 0.35); }
  50% { box-shadow: 0 8rpx 48rpx rgba(0, 229, 255, 0.50); }
}

/* 脉冲发光 */
@keyframes pulseGlow {
  0%, 100% { opacity: 1; box-shadow: var(--glow-primary); }
  50% { opacity: 0.7; box-shadow: 0 0 8rpx rgba(0, 229, 255, 0.15); }
}

/* 进度条流动 */
@keyframes progressFlow {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 骨架屏 */
@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 边框发光 */
@keyframes borderGlow {
  0%, 100% { border-color: rgba(0, 229, 255, 0.3); box-shadow: 0 0 12rpx rgba(0, 229, 255, 0.15); }
  50% { border-color: rgba(0, 229, 255, 0.6); box-shadow: 0 0 24rpx rgba(0, 229, 255, 0.30); }
}

/* 旋转发光边框（用于特殊容器） */
@keyframes rotateBorder {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
